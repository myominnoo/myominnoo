@article{Pelzom2017,
 abstract = {Bhutan is currently facing a double burden of non-communicable (NCDs) and communicable diseases, with rising trends of NCDs. The 2014 STEPS survey identified high prevalence of several NCD risk factors; however, associations with socio-demographic characteristics as well as clustering of risk factors were not assessed. This study aimed to determine the distribution and clustering of modifiable NCD risk factors among adults in Bhutan and their demographic and social determinants.},
 author = {Pelzom, Dorji and Isaakidis, Petros and Oo, Myo Minn and Gurung, Mongal Singh and Yangchen, Pemba},
 doi = {10.1186/s12889-017-4989-x},
 issn = {1471-2458},
 journal = {BMC Public Health},
 number = {1},
 pages = {975},
 title = {Alarming prevalence and clustering of modifiable noncommunicable disease risk factors among adults in Bhutan: a nationwide cross-sectional community survey},
 url = {https://doi.org/10.1186/s12889-017-4989-x},
 volume = {17},
 year = {2017}
}

